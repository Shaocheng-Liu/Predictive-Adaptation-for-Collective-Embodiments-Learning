<mujocoinclude>
  <compiler angle="radian" autolimits="true" inertiafromgeom="auto" inertiagrouprange="4 5"/>
  <option integrator="implicitfast"/>

  <asset>
    <material name="white" rgba="1 1 1 1"/>
    <material name="gray" rgba="0.753 0.753 0.753 1"/>
    <material name="xyz_col" rgba="0.3 0.3 1.0 0.5" shininess="0" specular="0.5"/>

    <mesh file="assets/link_base.stl"/>
    <mesh file="assets/link1.stl"/>
    <mesh file="assets/link2.stl"/>
    <mesh file="assets/link3.stl"/>
    <mesh file="assets/link4.stl"/>
    <mesh file="assets/link5.stl"/>
    <mesh file="assets/link6.stl"/>
    <mesh file="assets/link7.stl"/>
    <mesh file="assets/end_tool.stl"/>

    <mesh file="../objects/meshes/xyz_base/base.stl" name="base_mesh"/>
    <mesh file="../objects/meshes/xyz_base/eGripperBase.stl" name="eGripperBase"/>
    <mesh file="../objects/meshes/xyz_base/head.stl" name="head_mesh"/>
  </asset>

  <default>
    <default class="xarm7">
      <geom type="mesh" material="white"/>
      <joint axis="0 0 1" armature="0.1" range="-6.28319 6.28319" frictionloss="1"/>
      <general biastype="affine" ctrlrange="-6.28319 6.28319"/>
      
      <default class="size1">
        <joint damping="10"/>
        <general gainprm="1500" biasprm="0 -1500 -150" forcerange="-50 50"/>
      </default>
      <default class="size2">
        <joint damping="5"/>
        <general gainprm="1000" biasprm="0 -1000 -100" forcerange="-30 30"/>
      </default>
      <default class="size3">
        <joint damping="2"/>
        <general gainprm="800" biasprm="0 -800 -80" forcerange="-20 20"/>
      </default>

      <default class="base_col">
        <geom conaffinity="1" condim="4" contype="1" group="4" margin="0.001" material="xyz_col" solimp=".8 .9 .01" solref=".02 1"/>
      </default>

      <site size="0.001" rgba="1 0 0 1" group="4"/>
    </default>
  </default>
</mujocoinclude>